@model _23DH114228_MyStore.Models.Category

@{
    ViewBag.Title = "Delete";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="bg-success">Xóa Danh Mục</h2>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="form-horizontal">
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <h4>Bạn chắc không?</h4>
            <div class="form-group">
            </div>

            <div class=" control-label col-md-2">Tên Danh Mục </div>
            <div class="col-md-10">
                @*Hiển thị giá trị CategoryName*@
                @Html.DisplayFor(model => model.CategoryName)
            </div>
            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Xóa " class="btn btn-primary" /> |
                    @Html.ActionLink("Quay lại danh sách", "Index", null, new { @class = "btn btn-primary" })
                </div>
            </div>
        </div>
    </div>
}


