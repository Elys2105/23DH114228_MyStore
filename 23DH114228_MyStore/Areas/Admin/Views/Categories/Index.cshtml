@model IEnumerable<_23DH114228_MyStore.Models.Category>

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2> Danh Sách Danh Mục Sản Phẩm</h2>

<p>
    @Html.ActionLink("Thêm mới", "Create", null, new {@class = "btn btn-primary"})
</p>
<table class="table alert-info">
    <tr>
        <th>
            @*Html.DisplayNameFor(model => model.CategoryName)*@
            Tên Danh Mục
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.CategoryName)
        </td>
        <td>
            @Html.ActionLink("Cập nhật", "Edit", new { id = item.CategoryID },new { @class = "btn btn-primary"}) 
            @Html.ActionLink("Xóa", "Delete", new { id = item.CategoryID }, new { @class = "btn btn-primary" })
        </td>
    </tr>
}

</table>
